{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src/framework",
    "paths": {}
  },
  "include": ["src/framework/**/*.ts"],
  "exclude": ["node_modules", "src/framework/db.ts", "src/framework/compiler/directive.ts", "src/framework/compiler/bundle.ts"]
}
