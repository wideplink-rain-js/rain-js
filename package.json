{
  "name": "@rainfw/core",
  "version": "0.2.13",
  "description": "A TypeScript web framework for Cloudflare Workers",
  "bin": {
    "rainjs": "./cli/index.js"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/generate.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json",
    "typecheck:compiler": "tsc --noEmit -p tsconfig.compiler.json",
    "typecheck:db": "tsc --noEmit -p tsconfig.db.json",
    "ci": "biome ci . && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:generate": "node --test tests/generate.test.js",
    "bench": "node scripts/bench.js",
    "build:pkg": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && tsc -p tsconfig.client.build.json && node -e \"require('fs').writeFileSync('dist/package.json',JSON.stringify({type:'module'}))\"",
    "prepublishOnly": "npm run build:pkg",
    "release": "npm run ci && npm publish --access public"
  },
  "keywords": [
    "cloudflare-workers",
    "web-framework",
    "typescript",
    "file-based-routing",
    "jsx"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "peerDependencies": {
    "drizzle-orm": ">=0.40.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "typescript": {
      "optional": false
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./client": {
      "types": "./dist/client/hooks.d.ts",
      "import": "./dist/client/hooks.js"
    },
    "./client/runtime": {
      "types": "./dist/client/runtime.d.ts",
      "import": "./dist/client/runtime.js"
    },
    "./client/jsx-runtime": {
      "types": "./dist/client/jsx-runtime.d.ts",
      "import": "./dist/client/jsx-runtime.js"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1",
    "wrangler": "^4.76.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rainfw/core.git"
  },
  "homepage": "https://github.com/rainfw/core",
  "files": [
    "dist/",
    "cli/",
    "scripts/dev.js",
    "scripts/generate.js"
  ]
}
